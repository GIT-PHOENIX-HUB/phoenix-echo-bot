# Phoenix Echo Bot - Environment Configuration
# Copy to .env and fill in values before starting

# Core
ANTHROPIC_AUTH_TOKEN=
PHOENIX_WORKSPACE=~/Phoenix_Local/_GATEWAY
PHOENIX_PORT=18790
PHOENIX_BIND=127.0.0.1
PHOENIX_GATEWAY_TOKEN=
PHOENIX_MODEL=claude-sonnet-4-5-20250929

# Gateway Connection
PHOENIX_GATEWAY_WS_URL=ws://localhost:18790/ws

# Teams
PHOENIX_TEAMS_ENABLED=false
PHOENIX_TEAMS_APP_ID=
PHOENIX_TEAMS_APP_PASSWORD=
PHOENIX_TEAMS_TENANT_ID=

# Telegram
PHOENIX_TELEGRAM_ENABLED=false
PHOENIX_TELEGRAM_BOT_TOKEN=
PHOENIX_TELEGRAM_MINIAPP_URL=

# WhatsApp
PHOENIX_WHATSAPP_ENABLED=false

# Email
PHOENIX_EMAIL_ENABLED=false
PHOENIX_EMAIL_IMAP_HOST=
PHOENIX_EMAIL_IMAP_PORT=993
PHOENIX_EMAIL_SMTP_HOST=
PHOENIX_EMAIL_SMTP_PORT=587
PHOENIX_EMAIL_ADDRESS=
PHOENIX_EMAIL_PASSWORD=

# ServiceFusion
SERVICEFUSION_API_KEY=
SERVICEFUSION_BASE_URL=

# Rexel
REXEL_API_KEY=
REXEL_ACCOUNT_ID=
